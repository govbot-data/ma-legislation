  "abstracts": [
    {
      "note": "summary",
      "abstract": "By Representative MacGregor of Boston, a petition (accompanied by bill, House, No. 4267) of William F. MacGregor (with the approval of the mayor and city council) for legislation to authorize the appointment of Constantinos Papadopoulos as a police officer in the city of Boston, notwithstanding the maximum age requirement.  Public Service.  [Local Approval Received.]"
    }
  ],
